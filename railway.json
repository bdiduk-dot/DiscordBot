{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "startCommand": "python main.py",
    "restartPolicyCondition": "on-failure",
    "restartPolicyMaxRetries": 5,
    "restartPolicyType": "ON_FAILURE",
    "sleepApplication": false,
    "numReplicas": 1
  }
}
